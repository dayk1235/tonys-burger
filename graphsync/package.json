{
  "name": "graphsync",
  "version": "1.0.0",
  "description": "Cognitive graph synchronization engine — keeps your knowledge graph aligned with your repository",
  "type": "module",
  "bin": {
    "graphsync": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.2.5",
    "picocolors": "^1.1.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
