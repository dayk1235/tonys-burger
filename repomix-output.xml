@import "tailwindcss";
@import "tw-animate-css";
@import "shadcn/tailwind.css";

@custom-variant dark (&:is(.dark *));

/* ═══════════════════════════════════════════════════
   TONY'S BURGER — DESIGN TOKENS
   ═══════════════════════════════════════════════════
   This file defines the complete design token system.
   All values are centralized here. Do not hardcode
   colors or tokens in component files.
   ═══════════════════════════════════════════════════ */

@theme inline {
  /* ─── Fonts ────────────────────────────────── */
  --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
  --font-mono: ui-monospace, SFMono-Regular, monospace;
  --font-heading: "Playfair Display", ui-serif, Georgia, serif;

  /* ─── Brand Colors (static — never change) ── */
  --color-brand-primary: #8B1A1A;
  --color-brand-primary-hover: #6E1414;
  --color-brand-primary-light: #C0392B;
  --color-brand-secondary: #D4862A;
  --color-brand-secondary-hover: #B8721F;
  --color-brand-secondary-light: #E8A04A;

  /* ─── Experience Tokens (dynamic — themed) ── */
  --color-bg: var(--exp-bg, #0E0E0E);
  --color-bg-surface: var(--exp-bg-surface, #181818);
  --color-bg-surface-alt: var(--exp-bg-surface-alt, #222222);
  --color-bg-elevated: var(--exp-bg-elevated, #2A2A2A);

  --color-text-primary: var(--exp-text-primary, #F5F5F5);
  --color-text-secondary: var(--exp-text-secondary, #A0A0A0);
  --color-text-muted: var(--exp-text-muted, #6B6B6B);
  --color-text-inverse: #0E0E0E;

  --color-border: var(--exp-border, #333333);
  --color-border-light: var(--exp-border-light, #444444);

  /* ─── Semantic Colors (static) ─────────────── */
  --color-success: #2E7D32;
  --color-error: #D32F2F;
  --color-warning: #D4862A;
  --color-info: #1976D2;

  /* ─── Overlay ──────────────────────────────── */
  --color-overlay: rgba(0, 0, 0, 0.6);

  /* ─── shadcn/ui Theme Overrides ────────────── */
  --color-background: var(--color-bg);
  --color-foreground: var(--color-text-primary);
  --color-primary: var(--color-brand-primary);
  --color-primary-foreground: var(--color-text-primary);
  --color-secondary: var(--color-bg-surface-alt);
  --color-secondary-foreground: var(--color-text-primary);
  --color-muted: var(--color-bg-surface);
  --color-muted-foreground: var(--color-text-muted);
  --color-accent: var(--color-bg-surface-alt);
  --color-accent-foreground: var(--color-text-primary);
  --color-destructive: var(--color-error);
  --color-card: var(--color-bg-surface);
  --color-card-foreground: var(--color-text-primary);
  --color-popover: var(--color-bg-elevated);
  --color-popover-foreground: var(--color-text-primary);
  --color-input: var(--color-bg-surface-alt);
  --color-ring: var(--color-brand-primary);

  /* ─── Shadow Tokens (dynamic — themed) ────── */
  --shadow-sm: var(--exp-shadow-sm, 0 1px 2px rgba(0, 0, 0, 0.3));
  --shadow-md: var(--exp-shadow-md, 0 4px 6px rgba(0, 0, 0, 0.4));
  --shadow-lg: var(--exp-shadow-lg, 0 10px 15px rgba(0, 0, 0, 0.5));
  --shadow-xl: var(--exp-shadow-xl, 0 20px 25px rgba(0, 0, 0, 0.6));
  --shadow-glow-primary: var(--exp-shadow-glow-primary, 0 0 20px rgba(139, 26, 26, 0.3));
  --shadow-glow-secondary: var(--exp-shadow-glow-secondary, 0 0 20px rgba(212, 134, 42, 0.3));

  /* ─── Static Token Groups ──────────────────── */
  --radius-sm: 0.25rem;
  --radius-md: 0.5rem;
  --radius-lg: 0.75rem;
  --radius-xl: 1rem;
  --radius-2xl: 1.5rem;
  --radius-3xl: 2rem;
  --radius-4xl: 2.5rem;
  --radius-full: 9999px;

  --z-dropdown: 100;
  --z-sticky: 200;
  --z-overlay: 300;
  --z-modal: 400;
  --z-toast: 500;

  --duration-fast: 150ms;
  --duration-normal: 300ms;
  --duration-slow: 500ms;
  --easing-default: cubic-bezier(0.4, 0, 0.2, 1);
  --easing-in: cubic-bezier(0.4, 0, 1, 1);
  --easing-out: cubic-bezier(0, 0, 0.2, 1);
  --easing-bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);

  --container-max: 1280px;
  --container-narrow: 768px;
  --container-wide: 1440px;

  /* ─── shadcn/ui sidebar theme ──────────────── */
