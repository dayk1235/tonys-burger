  --color-sidebar-foreground: var(--color-text-primary);
  --color-sidebar-primary: var(--color-brand-primary);
  --color-sidebar-primary-foreground: var(--color-text-primary);
  --color-sidebar-accent: var(--color-bg-surface-alt);
  --color-sidebar-accent-foreground: var(--color-text-primary);
  --color-sidebar-border: var(--color-border);
  --color-sidebar-ring: var(--color-brand-primary);
}

/* ═══════════════════════════════════════════════════
   EXPERIENCE SYSTEM — CSS Custom Properties
   ═══════════════════════════════════════════════════
   :root contains the default (Morning) values.
   The ExperienceProvider overrides these at runtime
   via inline styles on <html>.
   ═══════════════════════════════════════════════════ */

:root {
  /* Morning (default) — Fresh, bright, calm */
  --exp-bg: #0E0E0E;
  --exp-bg-surface: #181818;
  --exp-bg-surface-alt: #222222;
  --exp-bg-elevated: #2A2A2A;
  --exp-text-primary: #F5F5F5;
  --exp-text-secondary: #A0A0A0;
  --exp-text-muted: #6B6B6B;
  --exp-border: #333333;
  --exp-border-light: #444444;
  --exp-shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
  --exp-shadow-md: 0 4px 6px rgba(0, 0, 0, 0.4);
  --exp-shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.5);
  --exp-shadow-xl: 0 20px 25px rgba(0, 0, 0, 0.6);
  --exp-shadow-glow-primary: 0 0 20px rgba(139, 26, 26, 0.3);
  --exp-shadow-glow-secondary: 0 0 20px rgba(212, 134, 42, 0.3);

  /* Smooth theme transitions */
  transition: background-color var(--duration-normal) var(--easing-default),
              color var(--duration-normal) var(--easing-default);
}

/* Focus — Elegant, professional, minimal (applied by JS, kept as fallback) */
:root.experience-focus {
  --exp-bg: #080808;
  --exp-bg-surface: #101010;
  --exp-bg-surface-alt: #181818;
  --exp-bg-elevated: #1E1E1E;
  --exp-text-primary: #E8E8E8;
  --exp-text-secondary: #888888;
  --exp-text-muted: #555555;
  --exp-border: #222222;
  --exp-border-light: #2A2A2A;
  --exp-shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.4);
  --exp-shadow-md: 0 4px 6px rgba(0, 0, 0, 0.5);
  --exp-shadow-lq: 0 10px 15px rgba(0, 0, 0, 0.6);
  --exp-shadow-xl: 0 20px 25px rgba(0, 0, 0, 0.7);
  --exp-shadow-glow-primary: none;
  --exp-shadow-glow-secondary: none;
}

/* ─── Base Styles ──────────────────────────────── */
@layer base {
  * {
    @apply border-border outline-ring/50;
  }

  html {
    scroll-behavior: smooth;
    font-family: var(--font-sans);
  }

  body {
    @apply bg-background text-foreground;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  ::selection {
    background-color: var(--color-brand-primary);
    color: var(--color-text-primary);
  }

  :focus-visible {
    outline: 2px solid var(--color-brand-primary);
    outline-offset: 2px;
  }
}

/* ─── Scrollbar Styles ─────────────────────────── */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: var(--color-bg);
}

::-webkit-scrollbar-thumb {
  background: var(--color-border);
  border-radius: var(--radius-full);
}

::-webkit-scrollbar-thumb:hover {
  background: var(--color-border-light);
}

/* ─── Hero Atmosphere Animations ─────────────── */
@layer utilities {
  .hero-smoke-a {
    animation: hero-smoke-a 18s ease-in-out infinite;
  }

  .hero-smoke-b {
    animation: hero-smoke-b 24s ease-in-out infinite;
  }

  .hero-smoke-c {
    animation: hero-smoke-c 20s ease-in-out infinite;
  }

  .hero-ember-a {
    animation: hero-ember-a 7s ease-in-out infinite;
  }

  .hero-ember-b {
    animation: hero-ember-b 9s ease-in-out infinite;
  }

  .hero-ember-c {
    animation: hero-ember-c 11s ease-in-out infinite;
  }

  .hero-flame {
    animation: hero-flame 5.5s ease-in-out infinite;
  }
}

@keyframes hero-smoke-a {
  0%, 100% {
    opacity: 0.18;
    transform: translate3d(0, 8px, 0) scale(1);
  }
  50% {
    opacity: 0.34;
    transform: translate3d(18px, -18px, 0) scale(1.08);
  }
}

@keyframes hero-smoke-b {
  0%, 100% {
    opacity: 0.12;
    transform: translate3d(0, 0, 0) scale(1);
  }
  50% {
    opacity: 0.26;
    transform: translate3d(-22px, -28px, 0) scale(1.12);
  }
}

@keyframes hero-smoke-c {
  0%, 100% {
    opacity: 0.16;
    transform: translate3d(0, 10px, 0) scale(1);
  }
  50% {
    opacity: 0.3;
    transform: translate3d(-12px, -22px, 0) scale(1.09);
  }
}

@keyframes hero-ember-a {
  0% {
    opacity: 0;
    transform: translate3d(0, 18px, 0) scale(0.8);
  }
  20% {
    opacity: 0.8;
  }
  100% {
    opacity: 0;
    transform: translate3d(-18px, -180px, 0) scale(1.15);
  }
}

@keyframes hero-ember-b {
  0% {
    opacity: 0;
    transform: translate3d(0, 16px, 0) scale(0.85);
  }
  18% {
    opacity: 0.75;
  }
  100% {
    opacity: 0;
    transform: translate3d(14px, -210px, 0) scale(1.1);
  }
}

@keyframes hero-ember-c {
  0% {
    opacity: 0;
    transform: translate3d(0, 20px, 0) scale(0.75);
  }
  24% {
    opacity: 0.7;
  }
  100% {
    opacity: 0;
    transform: translate3d(-8px, -200px, 0) scale(1.2);
  }
}

@keyframes hero-flame {
  0%, 100% {
    opacity: 0.18;
    transform: scale(1);
    filter: blur(22px);
  }
  50% {
    opacity: 0.36;
    transform: scale(1.06);
    filter: blur(28px);
  }
}

@media (prefers-reduced-motion: reduce) {
  .hero-smoke-a,
  .hero-smoke-b,
  .hero-smoke-c,
  .hero-ember-a,
  .hero-ember-b,
  .hero-ember-c,
  .hero-flame {
    animation: none !important;
  }
}
